@page "/spieler/{SpielerName}"
@rendermode InteractiveServer
@using TippspielWeb.Services
@using TippspielWeb.Models
@inject TippspielService TippspielService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject LiveUpdateService LiveUpdateService
@implements IDisposable

<h3 class="mb-4">
    Willkommen, @SpielerName! <span class="badge bg-success">Punkte: @aktuellerSpieler?.Punkte</span>
    <button class="btn btn-sm btn-outline-primary float-end" @onclick="@(() => Navigation.NavigateTo("/profil"))">
        <i class="bi bi-person-gear"></i> Profil bearbeiten
    </button>
</h3>

<div class="d-flex justify-content-end mb-2">
    <button class="btn btn-sm btn-outline-secondary me-2" @onclick="ToggleCompactMode">
        <i class="bi @(compactMode ? "bi-arrows-collapse" : "bi-arrows-expand")"></i>
        <span class="ms-1">@(compactMode ? "Kompakt" : "Standard")</span>
    </button>
</div>

<div class="toast-container-prahlen" aria-live="polite" aria-atomic="true">
    @if (!string.IsNullOrEmpty(prahlMeldung))
    {
        <div class="toast-prahlen prahlen-animation" role="status">
            <div class="fw-bold">@prahlenderSpieler</div>
            <div class="ms-2 me-2 flex-grow-1">@prahlMeldung</div>
            <button class="close-btn" @onclick="@(() => prahlMeldung = "")">✕</button>
        </div>
    }
</div>

<ul class="nav nav-tabs sticky-tabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "tipps" ? "active" : "")" @onclick="@(() => aktiverTab = "tipps")">Tipps abgeben</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "turnier" ? "active" : "")" @onclick="@(() => aktiverTab = "turnier")">Turniertipp</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "meine" ? "active" : "")" @onclick="@(() => aktiverTab = "meine")">Meine Tipps</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "alle" ? "active" : "")" @onclick="@(() => aktiverTab = "alle")">Alle Tipps</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "tabelle" ? "active" : "")" @onclick="@(() => aktiverTab = "tabelle")">Tabelle</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "export" ? "active" : "")" @onclick="@(() => aktiverTab = "export")">Export</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link @(aktiverTab == "statistik" ? "active" : "")" @onclick="@(() => aktiverTab = "statistik")">Statistik</button>
    </li>
</ul>

<div class="tab-content mt-3">
    @if (aktiverTab == "statistik")
    {
        // Berechne Statistiken nur einmal und cache sie
        var statistikKey = $"{SpielerName}_statistik";
        
        StatistikDaten stats;
        
        if (!_statistikCache.ContainsKey(statistikKey))
        {
            var meineTipps = spiele.Where(s => s.Tipps.ContainsKey(SpielerName)).ToList();
            var beendeteSpiele = meineTipps.Where(s => s.IstBeendet()).ToList();
            var richtigeTipps = beendeteSpiele.Where(s => BerechnePunkte(s.Tipps[SpielerName], s) > 0).Count();
            var exakteTipps = beendeteSpiele.Where(s => BerechnePunkte(s.Tipps[SpielerName], s) == 3).Count();
            var differenzTipps = beendeteSpiele.Where(s => BerechnePunkte(s.Tipps[SpielerName], s) == 2).Count();
                var tendenzTipps = beendeteSpiele.Where(s => BerechnePunkte(s.Tipps[SpielerName], s) == 1).Count();
                var falscheTipps = beendeteSpiele.Count - richtigeTipps;
                var tippQuote = beendeteSpiele.Count > 0 ? (richtigeTipps * 100.0 / beendeteSpiele.Count) : 0;
                
                stats = new StatistikDaten
                {
                    MeineTipps = meineTipps,
                    BeendeteSpiele = beendeteSpiele,
                    RichtigeTipps = richtigeTipps,
                    ExakteTipps = exakteTipps,
                    DifferenzTipps = differenzTipps,
                    TendenzTipps = tendenzTipps,
                    FalscheTipps = falscheTipps,
                    TippQuote = tippQuote
                };
                
                _statistikCache[statistikKey] = stats;
            }
            else
            {
                stats = _statistikCache[statistikKey];
            }
        
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-header bg-primary text-white fw-bold">
                        <i class="bi bi-graph-up"></i> Meine Tipp-Statistik
                    </div>
                    <div class="card-body">
                        <div class="row text-center mb-3">
                            <div class="col-6">
                                <h2 class="text-primary mb-0">@stats.MeineTipps.Count</h2>
                                <small class="text-muted">Tipps abgegeben</small>
                            </div>
                            <div class="col-6">
                                <h2 class="text-success mb-0">@aktuellerSpieler?.Punkte</h2>
                                <small class="text-muted">Gesamtpunkte</small>
                            </div>
                        </div>
                        
                        <hr />
                        
                        <h6 class="mb-3">Auswertung (nur beendete Spiele):</h6>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span><i class="bi bi-check-circle-fill text-success"></i> Richtige Tipps</span>
                                <strong>@stats.RichtigeTipps von @stats.BeendeteSpiele.Count (@stats.TippQuote.ToString("F1")%)</strong>
                            </div>
                            <div class="progress" style="height: 25px;">
                                @if (stats.BeendeteSpiele.Count > 0)
                                {
                                    var prozent = (stats.RichtigeTipps * 100.0 / stats.BeendeteSpiele.Count);
                                    <div class="progress-bar bg-success" style="width: @prozent%">@stats.RichtigeTipps</div>
                                    <div class="progress-bar bg-danger" style="width: @(100 - prozent)%">@stats.FalscheTipps</div>
                                }
                            </div>
                        </div>
                        
                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span><span class="badge bg-success">3 Punkte</span> Exakt richtig</span>
                                <strong>@stats.ExakteTipps</strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span><span class="badge bg-success">2 Punkte</span> Differenz richtig</span>
                                <strong>@stats.DifferenzTipps</strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span><span class="badge bg-warning">1 Punkt</span> Tendenz richtig</span>
                                <strong>@stats.TendenzTipps</strong>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span><span class="badge bg-danger">0 Punkte</span> Falsch</span>
                                <strong>@stats.FalscheTipps</strong>
                            </div>
                        </div>
                        
                        <hr />
                        
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Noch offene Spiele:</span>
                            <strong>@(spiele.Count - stats.BeendeteSpiele.Count)</strong>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-header bg-warning text-dark fw-bold">
                        <i class="bi bi-trophy-fill"></i> Mein Turniertipp
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(weltmeisterTipp) || !string.IsNullOrEmpty(vizemeisterTipp))
                        {
                            <div class="text-center">
                                <div class="mb-4">
                                    <i class="bi bi-trophy text-warning" style="font-size: 3rem;"></i>
                                    <h4 class="mt-2">Weltmeister</h4>
                                    <h3 class="text-primary">@(string.IsNullOrEmpty(weltmeisterTipp) ? "-" : weltmeisterTipp)</h3>
                                </div>
                                
                                <div>
                                    <i class="bi bi-award text-secondary" style="font-size: 2.5rem;"></i>
                                    <h5 class="mt-2">Vizemeister</h5>
                                    <h4 class="text-secondary">@(string.IsNullOrEmpty(vizemeisterTipp) ? "-" : vizemeisterTipp)</h4>
                                </div>
                            </div>
                            
                            <hr />
                            
                            <div class="text-center">
                                <button class="btn btn-primary" @onclick="@(() => aktiverTab = "turnier")">
                                    <i class="bi bi-pencil"></i> Turniertipp ändern
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning text-center">
                                <i class="bi bi-exclamation-triangle"></i>
                                <p class="mb-2">Du hast noch keinen Turniertipp abgegeben!</p>
                                <button class="btn btn-warning" @onclick="@(() => aktiverTab = "turnier")">
                                    <i class="bi bi-trophy"></i> Jetzt Turniertipp abgeben
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (aktiverTab == "tipps")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center">
                <h5 class="mb-0 me-3">Tipps abgeben</h5>
                <input class="form-control form-control-sm me-2" style="width: 260px;" placeholder="Suche Teams oder Spieltag..." @bind="searchQuery" />
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => searchQuery = string.Empty">Zurücksetzen</button>
            </div>
            <div>
                <label class="me-2">Filter:</label>
                <select class="form-select d-inline-block" style="width: auto;" @bind="gewaehlterSpieltag">
                    <option value="">Alle Spieltage</option>
                    @foreach (var st in spiele.Select(s => s.Spieltag).Distinct().OrderBy(s => s))
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>
        </div>
        @foreach (var gruppe in ApplySearchFilter(GetGefilterteSpiele()).GroupBy(s => s.Spieltag).OrderBy(g => g.Key))
        {
            var collapsed = _collapsedSpieltag.ContainsKey(gruppe.Key);
            <div class="card mb-3 spieltag-card @(collapsed ? "collapsed" : "")">
                <div class="card-header bg-primary text-white fw-bold d-flex justify-content-between align-items-center spieltag-header-sticky" @onclick="() => ToggleSpieltag(gruppe.Key)">
                    <div>SPIELTAG @gruppe.Key</div>
                    <div><i class="bi bi-chevron-down spieltag-toggle-icon"></i></div>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <small class="text-muted">Tipps dieses Spieltags</small>
                        <button class="btn btn-sm btn-success" @onclick="() => SpieltagTippsSpeichern(gruppe.Key)">
                            <i class="bi bi-save"></i> Alle speichern
                        </button>
                    </div>
                    @foreach (var spiel in gruppe.OrderBy(s => s.SpielDatum))
                    {
                        var lokalSpiel = spiel;
                        <div class="row mb-3 pb-3 border-bottom align-items-center">
                            <div class="col-md-5">
                                <div><strong>@lokalSpiel.Heimmannschaft vs @lokalSpiel.Gastmannschaft</strong></div>
                                <small class="text-muted">@lokalSpiel.SpielDatum.ToString("dd.MM.yyyy HH:mm")</small>
                                <div class="mt-1">
                                    @if (lokalSpiel.IstBeendet())
                                    {
                                        <span class="badge bg-secondary">Beendet</span>
                                    }
                                    else if (!TippspielService.IstTippMoeglich(lokalSpiel.SpielNummer))
                                    {
                                        <span class="badge badge-status-locked"><i class="bi bi-lock-fill"></i> Gesperrt</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-status-open"><i class="bi bi-unlock"></i> Tipps offen</span>
                                    }
                                    @if (lokalSpiel.IstLive())
                                    {
                                        <span class="badge bg-danger ms-2 blink-animation">🔴 Live</span>
                                    }
                                </div>
                                @if (lokalSpiel.IstBeendet())
                                {
                                    <div><small class="text-success">Ergebnis: @lokalSpiel.HeimTore:@lokalSpiel.GastTore</small></div>
                                }
                                else if (lokalSpiel.Tipps.ContainsKey(SpielerName))
                                {
                                    <div><small class="text-info">Aktueller Tipp: @lokalSpiel.Tipps[SpielerName].HeimTore:@lokalSpiel.Tipps[SpielerName].GastTore</small></div>
                                }
                            </div>
                            <div class="col-md-7">
                                @if (lokalSpiel.IstBeendet())
                                {
                                    <div class="alert alert-warning mb-0 py-2">Spiel beendet</div>
                                }
                                else if (!TippspielService.IstTippMoeglich(lokalSpiel.SpielNummer))
                                {
                                    <div class="alert alert-danger mb-0 py-2">
                                        <i class="bi bi-lock-fill"></i> Tipp-Abgabe gesperrt (weniger als 1 Stunde bis Spielbeginn)
                                    </div>
                                }
                                else
                                {
                                    var istGesperrt = !TippspielService.IstTippMoeglich(lokalSpiel.SpielNummer);
                                    <div class="row g-2 align-items-center">
                                        <div class="col-4">
                                            <label class="form-label small mb-1">@lokalSpiel.Heimmannschaft</label>
                                            <input type="number" class="form-control" 
                                                   value="@GetTippHeim(lokalSpiel)" 
                                                   @oninput="@(e => SetTippHeim(lokalSpiel, e.Value?.ToString()))"
                                                   min="0" max="20" 
                                                   placeholder="0"
                                                   disabled="@istGesperrt" />
                                        </div>
                                        <div class="col-1 text-center">
                                            <strong style="font-size: 1.5rem;">:</strong>
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label small mb-1">@lokalSpiel.Gastmannschaft</label>
                                            <input type="number" class="form-control" 
                                                   value="@GetTippGast(lokalSpiel)" 
                                                   @oninput="@(e => SetTippGast(lokalSpiel, e.Value?.ToString()))"
                                                   min="0" max="20" 
                                                   placeholder="0"
                                                   disabled="@istGesperrt" />
                                        </div>
                                        <div class="col-3">
                                            <label class="form-label small mb-1">&nbsp;</label>
                                            <button type="button" 
                                                    class="btn @(lokalSpiel.Tipps.ContainsKey(SpielerName) ? "btn-warning" : "btn-success") w-100" 
                                                    @onclick="@(() => TippSpeichern(lokalSpiel))"
                                                    disabled="@istGesperrt">
                                                <i class="bi bi-@(lokalSpiel.Tipps.ContainsKey(SpielerName) ? "pencil" : "check")"></i>
                                                @(lokalSpiel.Tipps.ContainsKey(SpielerName) ? "Tipp bearbeiten" : "Tipp abgeben")
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else if (aktiverTab == "turnier")
    {
        <div class="card">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-trophy-fill"></i> Turniertipp: Weltmeister & Vizemeister
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Tipp hier auf die beiden Finalisten! Diese Tipps können jederzeit geändert werden.
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-trophy text-warning"></i> Weltmeister
                        </label>
                        <input type="text" class="form-control" @bind="weltmeisterTipp" list="mannschaften-liste" placeholder="Mannschaft wählen oder eingeben" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">
                            <i class="bi bi-award text-secondary"></i> Vizemeister
                        </label>
                        <input type="text" class="form-control" @bind="vizemeisterTipp" list="mannschaften-liste" placeholder="Mannschaft wählen oder eingeben" />
                    </div>
                </div>
                
                <button class="btn btn-success" @onclick="TurniertippSpeichern">
                    <i class="bi bi-save"></i> Turniertipp speichern
                </button>
                
                @if (!string.IsNullOrEmpty(turniertippMeldung))
                {
                    <div class="alert alert-success mt-3 mb-0">
                        <i class="bi bi-check-circle"></i> @turniertippMeldung
                    </div>
                }
            </div>
        </div>
    }
    else if (aktiverTab == "meine")
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Meine Tipps</h5>
            <div>
                <label class="me-2">Filter:</label>
                <select class="form-select d-inline-block" style="width: auto;" @bind="gewaehlterSpieltag">
                    <option value="">Alle Spieltage</option>
                    @foreach (var st in spiele.Where(s => s.Tipps.ContainsKey(SpielerName)).Select(s => s.Spieltag).Distinct().OrderBy(s => s))
                    {
                        <option value="@st">@st</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="liveFilterMeine" @bind="filterNurLive" />
            <label class="form-check-label" for="liveFilterMeine">Nur Live-Spiele anzeigen</label>
            <small class="text-muted ms-2">Lazy-Load: @meineTippsLimit Spiele</small>
        </div>

        @foreach (var gruppe in GetMeineSpiele().GroupBy(s => s.Spieltag).OrderBy(g => g.Key))
        {
            <div class="card mb-3">
                <div class="card-header bg-info text-white fw-bold spieltag-header-sticky">SPIELTAG @gruppe.Key</div>
                <div class="list-group list-group-flush">
                    @foreach (var spiel in gruppe.OrderBy(s => s.SpielDatum))
                    {
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong>@spiel.Heimmannschaft vs @spiel.Gastmannschaft</strong>
                                <div class="text-end">
                                    @if (spiel.IstLive())
                                    {
                                        <span class="badge bg-danger blink-animation me-2">🔴 LIVE</span>
                                    }
                                    <span class="text-muted d-block">@spiel.SpielDatum.ToString("dd.MM.yyyy HH:mm")</span>
                                    <span class="badge @(IstOffen(spiel) ? "badge-status-open" : "badge-status-locked")">@(IstOffen(spiel) ? "Tipps offen" : (spiel.IstBeendet() ? "Beendet" : "Gesperrt"))</span>
                                </div>
                            </div>
                            <div class="mt-2 d-flex flex-wrap gap-2">
                                <span class="badge bg-primary">Mein Tipp: @spiel.Tipps[SpielerName].HeimTore:@spiel.Tipps[SpielerName].GastTore</span>
                                @if (spiel.IstBeendet())
                                {
                                    var punkte = BerechnePunkte(spiel.Tipps[SpielerName], spiel);
                                    <span class="badge bg-secondary">Ergebnis: @spiel.HeimTore:@spiel.GastTore</span>
                                    @if (punkte == 3)
                                    {
                                        <span class="badge bg-success">✓✓✓ 3 Punkte - Exakt!</span>
                                    }
                                    else if (punkte == 2)
                                    {
                                        <span class="badge bg-success">✓✓ 2 Punkte - Differenz</span>
                                    }
                                    else if (punkte == 1)
                                    {
                                        <span class="badge bg-warning">✓ 1 Punkt - Tendenz</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">✗ 0 Punkte</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Offen</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (GetMeineGefiltertCount() > GetMeineAnzahl())
        {
            <div class="d-grid">
                <button class="btn btn-outline-secondary" @onclick="() => MehrEigeneLaden()">Mehr laden (@GetMeineAnzahl() / @GetMeineGefiltertCount())</button>
            </div>
        }
    }
    else if (aktiverTab == "alle")
    {
        <div class="mb-3">
            <h5 class="mb-3">Alle Tipps (gesperrte Spiele)</h5>
            <div class="row">
                <div class="col-md-6">
                    <label class="me-2">Spieltag:</label>
                    <select class="form-select d-inline-block" style="width: auto;" @bind="gewaehlterSpieltag">
                        <option value="">Alle Spieltage</option>
                        @foreach (var st in spiele.Where(s => !TippspielService.IstTippMoeglich(s.SpielNummer)).Select(s => s.Spieltag).Distinct().OrderBy(s => s))
                        {
                            <option value="@st">@st</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="me-2">Benutzer:</label>
                    <select class="form-select d-inline-block" style="width: auto;" @bind="gewaehlterBenutzer">
                        <option value="">Alle Benutzer</option>
                        @foreach (var spieler in alleSpieler.OrderBy(s => s.Name))
                        {
                            <option value="@spieler.Name">@spieler.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2 mt-2">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="liveFilterAlle" @bind="filterNurLive" />
                    <label class="form-check-label" for="liveFilterAlle">Nur Live-Spiele</label>
                </div>
                <small class="text-muted">Lazy-Load aktiv: @alleTippsLimit Spiele</small>
            </div>
        </div>
        @if (!GetGesperrteListe().Any())
        {
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Aktuell sind keine gesperrten Spiele sichtbar. Tipps werden angezeigt, sobald ein Spiel in weniger als 1 Stunde beginnt.
            </div>
        }
        else
        {
            @foreach (var gruppe in GetGesperrteBegrenzt().GroupBy(s => s.Spieltag).OrderBy(g => g.Key))
            {
                <div class="card mb-3">
                    <div class="card-header bg-dark text-white fw-bold spieltag-header-sticky">
                        <div class="d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-lock-fill"></i> SPIELTAG @gruppe.Key</span>
                            <small class="text-muted">@gruppe.Count() Spiele</small>
                        </div>
                    </div>
                    <div class="card-body">
                        @foreach (var spiel in gruppe.OrderBy(s => s.SpielDatum))
                        {
                            <div class="mb-4 pb-3 border-bottom">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="mb-0">
                                        <strong>@spiel.Heimmannschaft vs @spiel.Gastmannschaft</strong>
                                        @if (spiel.IstLive())
                                        {
                                            <span class="badge bg-danger blink-animation ms-2">🔴 LIVE</span>
                                        }
                                    </h6>
                                    <div class="text-end">
                                        <span class="text-muted d-block">@spiel.SpielDatum.ToString("dd.MM.yyyy HH:mm")</span>
                                        <span class="badge badge-status-locked"><i class="bi bi-lock-fill"></i> Gesperrt</span>
                                    </div>
                                </div>
                                
                                @if (spiel.IstBeendet())
                                {
                                    <div class="alert alert-success mb-2 py-2">
                                        <strong>Endergebnis: @spiel.HeimTore : @spiel.GastTore</strong>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-warning mb-2 py-2">
                                        <i class="bi bi-lock-fill"></i> Tipp-Abgabe gesperrt - Spiel läuft oder startet bald
                                    </div>
                                }
                                
                                @if (spiel.Tipps.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-bordered mb-0 @(compactMode ? "table-compact" : "")">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Spieler</th>
                                                    <th class="text-center">Tipp</th>
                                                    @if (spiel.IstBeendet())
                                                    {
                                                        <th class="text-center">Punkte</th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var tippEntry in spiel.Tipps.Where(t => string.IsNullOrEmpty(gewaehlterBenutzer) || t.Key == gewaehlterBenutzer).OrderBy(t => t.Key))
                                                {
                                                    var istEigenerTipp = tippEntry.Key == SpielerName;
                                                    var punkte = spiel.IstBeendet() ? BerechnePunkte(tippEntry.Value, spiel) : -1;

                                                    <tr class="@(istEigenerTipp ? "table-info" : "")">
                                                        <td>
                                                            @tippEntry.Key
                                                            @if (istEigenerTipp)
                                                            {
                                                                <span class="badge bg-primary">Du</span>
                                                            }
                                                        </td>
                                                        <td class="text-center">
                                                            <strong>@tippEntry.Value.HeimTore : @tippEntry.Value.GastTore</strong>
                                                        </td>
                                                        @if (spiel.IstBeendet())
                                                        {
                                                            <td class="text-center">
                                                                @if (punkte == 3)
                                                                {
                                                                    <span class="badge bg-success">3 Punkte</span>
                                                                }
                                                                else if (punkte == 2)
                                                                {
                                                                    <span class="badge bg-success">2 Punkte</span>
                                                                }
                                                                else if (punkte == 1)
                                                                {
                                                                    <span class="badge bg-warning">1 Punkt</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-danger">0 Punkte</span>
                                                                }
                                                            </td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small">Keine Tipps abgegeben</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (GetGesperrteListe().Count > GetGesperrteBegrenzt().Count)
            {
                <div class="d-grid">
                    <button class="btn btn-outline-secondary" @onclick="() => MehrGesperrteLaden()">
                        Mehr laden (@GetGesperrteBegrenzt().Count / @GetGesperrteListe().Count)
                    </button>
                </div>
            }
        }
    }
    else if (aktiverTab == "tabelle")
    {
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h5 class="mb-0">Aktuelle Tabelle</h5>
            
            <!-- Prahlen-Button für Top 3 Spieler mit Cooldown-Hinweis -->
            @if (meinPlatz <= 3 && aktuellerSpieler?.Punkte >= 0)
            {
                <div class="d-flex flex-column align-items-start">
                    @if (TippspielService.KannPrahlen(SpielerName, out string grund))
                    {
                        <button class="btn btn-warning btn-lg" @onclick="Prahlen" disabled="@hatGeprahlt">
                            <i class="bi bi-trophy-fill"></i> @(hatGeprahlt ? "Du hast geprahlt! 🎉" : "Prahlen! 💪")
                        </button>
                        <small class="d-block mt-2 text-muted">Du bist auf Platz @meinPlatz - zeig es allen!</small>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-secondary" disabled title="@grund">
                                <i class="bi bi-trophy-fill"></i> Cooldown aktiv
                            </button>
                            <span class="badge bg-secondary" title="@grund">Cooldown</span>
                        </div>
                    }
                </div>
            }
            else if (meinPlatz > 3)
            {
                <small class="text-muted">💡 Tipp: Erreiche die Top 3, um prahlen zu können! (Aktuell Platz @meinPlatz)</small>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle @(compactMode ? "table-compact" : "")">
                <thead class="table-warning">
                    <tr>
                        <th style="width: 110px;">Platz</th>
                        <th>Spieler</th>
                        <th class="text-end">Punkte</th>
                        <th style="width: 160px;" class="text-end">Trend (letzte 5)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in ranking)
                    {
                        <tr class="@GetRowClass(r) @(r.Name == prahlenderSpieler && hatGeprahlt ? "prahlen-animation" : "")">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <strong>@r.Platz</strong>
                                    @if (r.PlatzDelta != 0)
                                    {
                                        <span class="@GetDeltaClass(r.PlatzDelta) platz-delta">
                                            <i class="bi @GetDeltaIcon(r.PlatzDelta)"></i>@Math.Abs(r.PlatzDelta)
                                        </span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="d-flex flex-column">
                                    <div>
                                        <strong>@r.Name</strong> @(r.IstAktuellerSpieler ? "👤" : "")
                                        @if (!r.KannPrahlen && r.PrahlHinweis is not null)
                                        {
                                            <span class="badge bg-secondary ms-2" title="@r.PrahlHinweis">Cooldown</span>
                                        }
                                    </div>
                                    <small class="text-muted">Sekundär-Sortierung: Trend & Name</small>
                                </div>
                            </td>
                            <td class="text-end fw-bold">@r.Punkte</td>
                            <td class="text-end">
                                <span class="badge @r.TrendCss">+@r.TrendPunkte</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (aktiverTab == "export")
    {
        <h5>Excel Export</h5>
        <div class="card">
            <div class="card-body">
                <p>Exportiere deine persönlichen Tipps und die aktuelle Tabelle als Excel-Datei.</p>
                <p class="text-muted"><small>Hinweis: Bei "Alle Tipps" werden nur die Tipps von abgeschlossenen Spielen angezeigt.</small></p>
                <button type="button" class="btn btn-success" @onclick="ExcelExportieren">
                    <i class="bi bi-file-earmark-excel"></i> Excel exportieren
                </button>
            </div>
        </div>
    }
</div>

<datalist id="mannschaften-liste">
    @foreach (var mannschaft in mannschaftsListe)
    {
        <option value="@mannschaft.Name">@mannschaft.Name</option>
    }
</datalist>

<div class="mt-3">
    <button class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/login"))">Zurück zum Login</button>
</div>

@code {
    [Parameter]
    public string SpielerName { get; set; } = "";

    private class StatistikDaten
    {
        public List<Spiel> MeineTipps { get; set; } = new();
        public List<Spiel> BeendeteSpiele { get; set; } = new();
        public int RichtigeTipps { get; set; }
        public int ExakteTipps { get; set; }
        public int DifferenzTipps { get; set; }
        public int TendenzTipps { get; set; }
        public int FalscheTipps { get; set; }
        public double TippQuote { get; set; }
    }

    private List<Spiel> spiele = new();
    private List<Spieler> alleSpieler = new();
    private Spieler? aktuellerSpieler;
    private string aktiverTab = "tipps";
    private Dictionary<int, (int heim, int gast)> tempTipps = new();
    private string gewaehlterSpieltag = "";
    private string gewaehlterBenutzer = "";
    private string weltmeisterTipp = "";
    private string vizemeisterTipp = "";
    private string turniertippMeldung = "";
    private List<Mannschaft> mannschaftsListe = new();
    private bool hatGeprahlt = false;
    private string prahlMeldung = "";
    private string prahlenderSpieler = ""; // Name des Spielers der prahlt
    private DateTime letztesPrahlEvent = DateTime.MinValue;
    private bool compactMode = false;
    private bool filterNurLive = false;
    private int alleTippsLimit = 30;
    private int meineTippsLimit = 30;
    private List<SpielerRanking> ranking = new();
    private int meinPlatz = 0;
    
    // Performance-Optimierungen: Caching
    private Dictionary<string, List<Spiel>> _spieltagCache = new();
    private Dictionary<string, StatistikDaten> _statistikCache = new();
    private bool _isDatenGeladen = false;
    // Collapsed state per Spieltag
    private Dictionary<string, bool> _collapsedSpieltag = new();

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(SpielerName))
        {
            Navigation.NavigateTo("/login");
            return;
        }
        
        // Registriere Event-Handler für Prahl-Aktionen
        LiveUpdateService.OnPrahlAktion += HandlePrahlEvent;
        
        LadeDaten();
    }
    
    private void LadeDaten()
    {
        if (_isDatenGeladen) return;
        
        spiele = TippspielService.GetAlleSpiele();
        alleSpieler = TippspielService.GetAlleSpieler();
        aktuellerSpieler = alleSpieler.FirstOrDefault(s => s.Name == SpielerName);
        mannschaftsListe = TippspielService.GetAlleMannschaften();
        
        _isDatenGeladen = true;
        
        // Lade bestehende Turniertipps
        var (wm, vm) = TippspielService.GetTurniertipp(SpielerName);
        weltmeisterTipp = wm ?? "";
        vizemeisterTipp = vm ?? "";
        
        if (aktuellerSpieler == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        
        // Initialisiere temporäre Tipps
        foreach (var spiel in spiele)
        {
            if (spiel.Tipps.ContainsKey(SpielerName))
            {
                var tipp = spiel.Tipps[SpielerName];
                tempTipps[spiel.SpielNummer] = (tipp.HeimTore, tipp.GastTore);
            }
            else
            {
                tempTipps[spiel.SpielNummer] = (0, 0);
            }
        }

        AktualisiereRanking();
    }

    private int GetTippHeim(Spiel spiel)
    {
        if (tempTipps.ContainsKey(spiel.SpielNummer))
            return tempTipps[spiel.SpielNummer].Item1;
        return 0;
    }

    private int GetTippGast(Spiel spiel)
    {
        if (tempTipps.ContainsKey(spiel.SpielNummer))
            return tempTipps[spiel.SpielNummer].Item2;
        return 0;
    }

    private void SetTippHeim(Spiel spiel, string? value)
    {
        if (int.TryParse(value, out int heim))
        {
            var current = tempTipps.ContainsKey(spiel.SpielNummer) ? tempTipps[spiel.SpielNummer] : (0, 0);
            tempTipps[spiel.SpielNummer] = (heim, current.Item2);
        }
    }

    private void SetTippGast(Spiel spiel, string? value)
    {
        if (int.TryParse(value, out int gast))
        {
            var current = tempTipps.ContainsKey(spiel.SpielNummer) ? tempTipps[spiel.SpielNummer] : (0, 0);
            tempTipps[spiel.SpielNummer] = (current.Item1, gast);
        }
    }

    private void TippSpeichern(Spiel spiel)
    {
        if (!spiel.IstBeendet() && 
            TippspielService.IstTippMoeglich(spiel.SpielNummer) && 
            tempTipps.ContainsKey(spiel.SpielNummer))
        {
            var (heim, gast) = tempTipps[spiel.SpielNummer];
            if (TippspielService.TippAbgeben(spiel.SpielNummer, SpielerName, heim, gast))
            {
                // Aktualisiere nur die betroffenen Daten
                spiele = TippspielService.GetAlleSpiele();
                alleSpieler = TippspielService.GetAlleSpieler();
                aktuellerSpieler = alleSpieler.FirstOrDefault(s => s.Name == SpielerName);
                AktualisiereRanking();
                
                // Lösche Cache nach Tipp-Abgabe
                CacheLöschen();
                
                StateHasChanged();
            }
        }
    }

    private int BerechnePunkte(Tipp tipp, Spiel spiel)
    {
        if (!spiel.IstBeendet()) return 0;

        int heimTore = spiel.HeimTore ?? 0;
        int gastTore = spiel.GastTore ?? 0;

        if (tipp.HeimTore == heimTore && tipp.GastTore == gastTore)
            return 3;

        int tippDiff = tipp.HeimTore - tipp.GastTore;
        int spielDiff = heimTore - gastTore;

        if (tippDiff == spielDiff)
            return 2;

        if ((tippDiff > 0 && spielDiff > 0) || 
            (tippDiff == 0 && spielDiff == 0) || 
            (tippDiff < 0 && spielDiff < 0))
            return 1;

        return 0;
    }

    private async Task ExcelExportieren()
    {
        try
        {
            var excelDaten = TippspielService.ExportiereNachExcelFuerSpieler(SpielerName);
            var base64 = Convert.ToBase64String(excelDaten);
            var dateiname = $"Tippspiel_{SpielerName}_{DateTime.Now:yyyyMMdd}.xlsx";
            await JS.InvokeVoidAsync("downloadFile", dateiname, base64);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fehler beim Excel-Export: {ex.Message}");
        }
    }

    private void TurniertippSpeichern()
    {
        TippspielService.TurniertippSpeichern(SpielerName, 
            string.IsNullOrWhiteSpace(weltmeisterTipp) ? null : weltmeisterTipp, 
            string.IsNullOrWhiteSpace(vizemeisterTipp) ? null : vizemeisterTipp);
        
        turniertippMeldung = "Turniertipp erfolgreich gespeichert!";
        StateHasChanged();
        
        // Meldung nach 3 Sekunden ausblenden
        Task.Delay(3000).ContinueWith(_ => 
        {
            turniertippMeldung = "";
            InvokeAsync(StateHasChanged);
        });
    }

    private List<Spiel> GetGefilterteSpiele()
    {
        if (string.IsNullOrEmpty(gewaehlterSpieltag))
            return spiele;
            
        // Cache für gefilterte Spiele
        if (!_spieltagCache.ContainsKey(gewaehlterSpieltag))
        {
            _spieltagCache[gewaehlterSpieltag] = spiele.Where(s => s.Spieltag == gewaehlterSpieltag).ToList();
        }
        return _spieltagCache[gewaehlterSpieltag];
    }
    
    private void CacheLöschen()
    {
        _spieltagCache.Clear();
        _statistikCache.Clear();
    }

    private record SpielerRanking(
        string Name,
        int Punkte,
        int TrendPunkte,
        int Platz,
        int PlatzVorher,
        int PlatzDelta,
        string TrendCss,
        bool IstAktuellerSpieler,
        bool KannPrahlen,
        string? PrahlHinweis);

    private record RankingEintrag(string Name, int Punkte, int Trend);

    private List<SpielerRanking> BerechneRanking()
    {
        var rankingDaten = alleSpieler
            .Select(s => new RankingEintrag(s.Name, s.Punkte, BerechneTrendPunkte(s.Name)))
            .OrderByDescending(x => x.Punkte)
            .ThenByDescending(x => x.Trend)
            .ThenBy(x => x.Name)
            .ToList();

        var platzMap = BerechnePlaetze(rankingDaten);

        var rankingVorherDaten = alleSpieler
            .Select(s => new RankingEintrag(s.Name, s.Punkte - BerechneLetztePunkte(s.Name), BerechneTrendPunkte(s.Name)))
            .OrderByDescending(x => x.Punkte)
            .ThenByDescending(x => x.Trend)
            .ThenBy(x => x.Name)
            .ToList();

        var platzMapVorher = BerechnePlaetze(rankingVorherDaten);

        var result = new List<SpielerRanking>();
        foreach (var item in rankingDaten)
        {
            var platz = platzMap[item.Name];
            var platzVorher = platzMapVorher.TryGetValue(item.Name, out var pv) ? pv : platz;
            var delta = platzVorher - platz;

            var kannPrahl = TippspielService.KannPrahlen(item.Name, out string grund);

            result.Add(new SpielerRanking(
                item.Name,
                item.Punkte,
                item.Trend,
                platz,
                platzVorher,
                delta,
                TrendCssClass(item.Trend),
                item.Name == SpielerName,
                kannPrahl,
                kannPrahl ? null : grund
            ));
        }

        return result;
    }

    private Dictionary<string, int> BerechnePlaetze(IEnumerable<RankingEintrag> daten)
    {
        var map = new Dictionary<string, int>();
        int platz = 1;
        int index = 0;
        int letzterPunkte = int.MinValue;
        int letzterTrend = int.MinValue;

        foreach (var item in daten)
        {
            if (index > 0 && (item.Punkte != letzterPunkte || item.Trend != letzterTrend))
            {
                platz = index + 1;
            }

            map[item.Name] = platz;
            letzterPunkte = item.Punkte;
            letzterTrend = item.Trend;
            index++;
        }

        return map;
    }

    private int BerechneTrendPunkte(string spielerName, int anzahl = 5)
    {
        var trendSpiele = spiele
            .Where(s => s.IstBeendet() && s.Tipps.ContainsKey(spielerName))
            .OrderByDescending(s => s.SpielDatum)
            .Take(anzahl);

        int summe = 0;
        foreach (var spiel in trendSpiele)
        {
            summe += BerechnePunkte(spiel.Tipps[spielerName], spiel);
        }
        return summe;
    }

    private int BerechneLetztePunkte(string spielerName)
    {
        var letztesSpiel = spiele
            .Where(s => s.IstBeendet() && s.Tipps.ContainsKey(spielerName))
            .OrderByDescending(s => s.SpielDatum)
            .FirstOrDefault();

        if (letztesSpiel == null) return 0;

        return BerechnePunkte(letztesSpiel.Tipps[spielerName], letztesSpiel);
    }

    private string TrendCssClass(int trend)
    {
        if (trend >= 12) return "trend-badge-hot";
        if (trend >= 8) return "trend-badge-warm";
        if (trend >= 4) return "trend-badge-neutral";
        if (trend > 0) return "trend-badge-cool";
        return "trend-badge-cold";
    }

    private void AktualisiereRanking()
    {
        ranking = BerechneRanking();
        var meinEintrag = ranking.FirstOrDefault(r => r.Name == SpielerName);
        meinPlatz = meinEintrag?.Platz ?? ranking.Count + 1;
    }

    private IEnumerable<Spiel> WendeLiveFilter(IEnumerable<Spiel> source)
    {
        return filterNurLive ? source.Where(s => s.IstLive()) : source;
    }

    private List<Spiel> GetMeineSpiele()
    {
        return WendeLiveFilter(GetGefilterteSpiele()
            .Where(s => s.Tipps.ContainsKey(SpielerName))
            .OrderBy(s => s.SpielDatum))
            .Take(meineTippsLimit)
            .ToList();
    }

    private List<Spiel> GetGesperrteListe()
    {
        return WendeLiveFilter(GetGefilterteSpiele()
            .Where(s => !TippspielService.IstTippMoeglich(s.SpielNummer))
            .OrderBy(s => s.SpielDatum))
            .ToList();
    }

    private List<Spiel> GetGesperrteBegrenzt()
    {
        return GetGesperrteListe().Take(alleTippsLimit).ToList();
    }

    private int GetMeineGefiltertCount() => GetGefilterteSpiele().Count(s => s.Tipps.ContainsKey(SpielerName));
    private int GetMeineAnzahl() => GetMeineSpiele().Count;

    private bool IstOffen(Spiel spiel) => !spiel.IstBeendet() && TippspielService.IstTippMoeglich(spiel.SpielNummer);

    private string GetRowClass(SpielerRanking r)
    {
        var rowClass = r.Platz switch { 1 => "table-warning", 2 => "table-secondary", 3 => "table-danger", _ => "" };
        if (r.IstAktuellerSpieler) rowClass = "table-info";
        return rowClass;
    }

    private string GetDeltaIcon(int delta) => delta < 0 ? "bi-arrow-up-short" : "bi-arrow-down-short";
    private string GetDeltaClass(int delta) => delta < 0 ? "text-success" : "text-danger";

    private void SpieltagTippsSpeichern(string spieltag)
    {
        var offeneSpiele = spiele
            .Where(s => s.Spieltag == spieltag && !s.IstBeendet() && TippspielService.IstTippMoeglich(s.SpielNummer))
            .ToList();

        bool geaendert = false;

        foreach (var spiel in offeneSpiele)
        {
            if (tempTipps.TryGetValue(spiel.SpielNummer, out var tipp))
            {
                var gespeichert = TippspielService.TippAbgeben(spiel.SpielNummer, SpielerName, tipp.Item1, tipp.Item2);
                geaendert = geaendert || gespeichert;
            }
        }

        if (geaendert)
        {
            spiele = TippspielService.GetAlleSpiele();
            alleSpieler = TippspielService.GetAlleSpieler();
            aktuellerSpieler = alleSpieler.FirstOrDefault(s => s.Name == SpielerName);
            AktualisiereRanking();
            CacheLöschen();
            StateHasChanged();
        }
    }

    private void MehrGesperrteLaden(int anzahl = 20)
    {
        alleTippsLimit += anzahl;
    }

    private void MehrEigeneLaden(int anzahl = 20)
    {
        meineTippsLimit += anzahl;
    }

    private IEnumerable<Spiel> ApplySearchFilter(IEnumerable<Spiel> source)
    {
        if (string.IsNullOrWhiteSpace(searchQuery)) return source;
        var q = searchQuery.Trim().ToLowerInvariant();
        return source.Where(s => s.Heimmannschaft.ToLowerInvariant().Contains(q) || s.Gastmannschaft.ToLowerInvariant().Contains(q) || s.Spieltag.ToLowerInvariant().Contains(q));
    }

    private void ToggleCompactMode()
    {
        compactMode = !compactMode;
        // kleine UI-Änderung sofort anzeigen
        InvokeAsync(StateHasChanged);
    }

    private string searchQuery = "";

    private void ToggleSpieltag(string spieltag)
    {
        if (_collapsedSpieltag.ContainsKey(spieltag))
            _collapsedSpieltag.Remove(spieltag);
        else
            _collapsedSpieltag[spieltag] = true;

        // persistieren
        try
        {
            var keys = _collapsedSpieltag.Keys.ToList();
            var json = System.Text.Json.JsonSerializer.Serialize(keys);
            JS.InvokeVoidAsync("localStorage.setItem", "tippspiel_collapsed_groups", json);
        }
        catch { }
    }
    
    private void Prahlen()
    {
        var sortiert = alleSpieler.OrderByDescending(s => s.Punkte).ToList();
        var meinPlatz = sortiert.FindIndex(s => s.Name == SpielerName) + 1;
        
        string[] prahlSprueche = new string[]
        {
            $"{SpielerName} ist einfach unschlagbar! 🏆",
            $"Niemand kann {SpielerName} stoppen! 💪",
            $"{SpielerName} zeigt allen wie es geht! 🎯",
            $"Platz {meinPlatz}? {SpielerName} macht das im Schlaf! 😎",
            $"{SpielerName} ist der wahre Champion! 👑",
            $"Alle anderen können einpacken - {SpielerName} dominiert! ⚡",
            $"{SpielerName} tippt wie ein Profi! 🌟"
        };
        
        var random = new Random();
        prahlMeldung = prahlSprueche[random.Next(prahlSprueche.Length)];
        
        // Speichere Prahl-Aktion
        TippspielService.PrahlAktionSpeichern(SpielerName, prahlMeldung);
        
        // Triggere Event für alle Benutzer
        LiveUpdateService.TriggerPrahlAktion(SpielerName, prahlMeldung);
        
        StateHasChanged();
        
        // Reset nach 5 Sekunden
        Task.Delay(5000).ContinueWith(_ => 
        {
            hatGeprahlt = false;
            InvokeAsync(StateHasChanged);
        });
    }
    
    private void HandlePrahlEvent(PrahlEvent prahlEvent)
    {
        // Verhindere mehrfache Events innerhalb kurzer Zeit
        if ((DateTime.Now - letztesPrahlEvent).TotalSeconds < 1)
            return;
            
        letztesPrahlEvent = DateTime.Now;
        prahlenderSpieler = prahlEvent.SpielerName;
        prahlMeldung = prahlEvent.Nachricht;
        hatGeprahlt = true;
        
        InvokeAsync(() =>
        {
            StateHasChanged();
            
            // Reset nach 5 Sekunden
            Task.Delay(5000).ContinueWith(_ =>
            {
                hatGeprahlt = false;
                prahlenderSpieler = "";
                InvokeAsync(StateHasChanged);
            });
        });
    }
    
    public void Dispose()
    {
        LiveUpdateService.OnPrahlAktion -= HandlePrahlEvent;
    }

        protected override async Task OnInitializedAsync()
        {
            // Versuche compactMode aus localStorage zu lesen
            try
            {
                var val = await JS.InvokeAsync<string>("localStorage.getItem", "tippspiel_compact_mode");
                if (!string.IsNullOrEmpty(val) && bool.TryParse(val, out bool parsed))
                {
                    compactMode = parsed;
                }
            }
            catch { /* ignore */ }

            // Lade bereits vorhandene kollapsen Zustände (optional)
            try
            {
                var collapsedJson = await JS.InvokeAsync<string>("localStorage.getItem", "tippspiel_collapsed_groups");
                if (!string.IsNullOrEmpty(collapsedJson))
                {
                    var list = System.Text.Json.JsonSerializer.Deserialize<List<string>>(collapsedJson);
                    if (list != null)
                    {
                        foreach (var key in list)
                            _collapsedSpieltag[key] = true;
                    }
                }
            }
            catch { }

            await Task.CompletedTask;
        }
}
