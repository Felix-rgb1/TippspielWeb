@page "/admin"
@rendermode InteractiveServer
@using TippspielWeb.Services
@using TippspielWeb.Models
@inject TippspielService TippspielService
@inject OpenLigaDBService OpenLigaDBService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h3 class="mb-4">Administrator-Bereich</h3>

<ul class="nav nav-tabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link @(tab == "mannschaften" ? "active" : "")" @onclick="@(() => WechsleTab("mannschaften"))">Mannschaften</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "spiele" ? "active" : "")" @onclick="@(() => WechsleTab("spiele"))">Spiele</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "bundesliga" ? "active" : "")" @onclick="@(() => WechsleTab("bundesliga"))">Bundesliga Import</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "tipps" ? "active" : "")" @onclick="@(() => WechsleTab("tipps"))">Tipps</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "turniertipps" ? "active" : "")" @onclick="@(() => WechsleTab("turniertipps"))">Turniertipps</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "tabelle" ? "active" : "")" @onclick="@(() => WechsleTab("tabelle"))">Tabelle</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "export" ? "active" : "")" @onclick="@(() => WechsleTab("export"))">Export</button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(tab == "benutzer" ? "active" : "")" @onclick="@(() => WechsleTab("benutzer"))">Benutzerverwaltung</button>
    </li>
</ul>

<div class="tab-content mt-3">
    @if (tab == "mannschaften")
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-shield-fill"></i> Neue Mannschaft</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <input type="text" 
                                   class="form-control" 
                                   placeholder="Mannschaftsname eingeben" 
                                   @bind="neueMannschaft"
                                   @onkeypress="@(e => { if (e.Key == "Enter") MannschaftHinzufuegen(); })" />
                        </div>
                        <button class="btn btn-success" @onclick="MannschaftHinzufuegen">
                            <i class="bi bi-plus-circle"></i> Mannschaft hinzufügen
                        </button>
                        @if (!string.IsNullOrEmpty(mannschaftsMeldung))
                        {
                            <div class="alert alert-info mt-2">@mannschaftsMeldung</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-list-ul"></i> Alle Mannschaften (@mannschaftsListe.Count)</h5>
                    </div>
                    <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                        @if (!mannschaftsListe.Any())
                        {
                            <div class="list-group-item text-muted">Noch keine Mannschaften vorhanden</div>
                        }
                        else
                        {
                            @foreach (var mannschaft in mannschaftsListe.OrderBy(m => m.Name))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    @if (bearbeiteteMannschaft == mannschaft.Name)
                                    {
                                        <input type="text" 
                                               class="form-control form-control-sm me-2" 
                                               @bind="neuerMannschaftsname"
                                               @onkeypress="@(e => { if (e.Key == "Enter") MannschaftUmbenennenSpeichern(mannschaft.Name); })" />
                                        <div>
                                            <button class="btn btn-sm btn-success me-1" @onclick="@(() => MannschaftUmbenennenSpeichern(mannschaft.Name))">
                                                <i class="bi bi-check"></i>
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="@(() => bearbeiteteMannschaft = null)">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <strong>@mannschaft.Name</strong>
                                        <div>
                                            <button class="btn btn-sm btn-warning me-1" @onclick="@(() => { bearbeiteteMannschaft = mannschaft.Name; neuerMannschaftsname = mannschaft.Name; })">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="@(() => MannschaftLoeschen(mannschaft.Name))">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (tab == "benutzer")
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-people"></i> Benutzerverwaltung</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(benutzerMeldung))
                {
                    <div class="alert alert-info alert-dismissible fade show">
                        @benutzerMeldung
                        <button type="button" class="btn-close" @onclick="@(() => benutzerMeldung = "")"></button>
                    </div>
                }

                @if (benutzerListe == null || !benutzerListe.Any())
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> Keine Benutzer gefunden. 
                        @if (benutzerListe == null)
                        {
                            <span>(Liste ist null)</span>
                        }
                        else
                        {
                            <span>(Liste ist leer - @benutzerListe.Count Einträge)</span>
                        }
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Benutzername</th>
                                <th>Registriert am</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var benutzer in benutzerListe)
                            {
                                <tr>
                                    <td>
                                        @if (bearbeiteterBenutzer == benutzer.Benutzername)
                                        {
                                            <input type="text" class="form-control form-control-sm" @bind="neuerBenutzernameAdmin" />
                                        }
                                        else
                                        {
                                            <strong>@benutzer.Benutzername</strong>
                                            @if (benutzer.IstAdmin)
                                            {
                                                <span class="badge bg-warning">Admin</span>
                                            }
                                        }
                                    </td>
                                    <td>@benutzer.RegistriertAm.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (bearbeiteterBenutzer == benutzer.Benutzername)
                                        {
                                            <button class="btn btn-sm btn-success me-1" @onclick="@(() => BenutzernameAendernAdmin(benutzer.Benutzername))">
                                                <i class="bi bi-check"></i> Speichern
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="@(() => bearbeiteterBenutzer = null)">
                                                <i class="bi bi-x"></i> Abbrechen
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-primary me-1" @onclick="@(() => { bearbeiteterBenutzer = benutzer.Benutzername; neuerBenutzernameAdmin = benutzer.Benutzername; })">
                                                <i class="bi bi-pencil"></i> Name ändern
                                            </button>
                                            <button class="btn btn-sm btn-warning me-1" @onclick="@(() => PasswortZuruecksetzen(benutzer.Benutzername))">
                                                <i class="bi bi-key"></i> Passwort zurücksetzen
                                            </button>
                                            @if (!benutzer.IstAdmin)
                                            {
                                                <button class="btn btn-sm btn-danger" @onclick="@(() => BenutzerLoeschenAdmin(benutzer.Benutzername))">
                                                    <i class="bi bi-trash"></i> Löschen
                                                </button>
                                            }
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (zeigePasswortReset)
                {
                    <div class="card mt-3">
                        <div class="card-header bg-warning">
                            <h6 class="mb-0">Passwort zurücksetzen für: <strong>@resetBenutzer</strong></h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Neues Passwort</label>
                                <input type="password" class="form-control" @bind="neuesPasswortAdmin" placeholder="Mindestens 6 Zeichen" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Passwort wiederholen</label>
                                <input type="password" class="form-control" @bind="neuesPasswortAdminWiederholung" placeholder="Passwort erneut eingeben" />
                            </div>
                            <button class="btn btn-warning me-2" 
                                    @onclick="PasswortZuruecksetzenBestaetigen"
                                    disabled="@(string.IsNullOrEmpty(neuesPasswortAdmin) || neuesPasswortAdmin.Length < 6 || neuesPasswortAdmin != neuesPasswortAdminWiederholung)">
                                <i class="bi bi-save"></i> Passwort speichern
                            </button>
                            <button class="btn btn-secondary" @onclick="@(() => { zeigePasswortReset = false; neuesPasswortAdmin = ""; neuesPasswortAdminWiederholung = ""; })">
                                Abbrechen
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else if (tab == "spiele")
    {
        @if (bearbeitungsSpiel != null)
        {
            <div class="card mb-3 border-primary">
                <div class="card-header bg-primary text-white">Spiel bearbeiten</div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label">Spieltag</label>
                            <input type="text" class="form-control" @bind="bearbeitungSpieltag" placeholder="z.B. 1, A, Viertelfinale" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Heimmannschaft</label>
                            <input type="text" class="form-control" @bind="bearbeitungHeimmannschaft" list="mannschaften-liste" placeholder="Mannschaft eingeben" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Gastmannschaft</label>
                            <input type="text" class="form-control" @bind="bearbeitungGastmannschaft" list="mannschaften-liste" placeholder="Mannschaft eingeben" />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label">Datum & Uhrzeit</label>
                            <input type="datetime-local" class="form-control" @bind="bearbeitungDatum" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" @onclick="SpielBearbeitenSpeichern">Speichern</button>
                        <button class="btn btn-secondary" @onclick="SpielBearbeitenAbbrechen">Abbrechen</button>
                    </div>
                </div>
            </div>
        }
        
        <div class="row">
            <div class="col-md-5">
                <div class="card">
                    <div class="card-header bg-success text-white">Neues Spiel</div>
                    <div class="card-body">
                        <div class="col-md-6">
                            <label class="form-label">Spieltag</label>
                            <input type="text" class="form-control" @bind="neuerSpieltag" placeholder="z.B. 1, A, Viertelfinale" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Heimmannschaft</label>
                            <input type="text" class="form-control" @bind="neueHeimmannschaft" list="mannschaften-liste" placeholder="Mannschaft eingeben oder auswählen" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Gastmannschaft</label>
                            <input type="text" class="form-control" @bind="neueGastmannschaft" list="mannschaften-liste" placeholder="Mannschaft eingeben oder auswählen" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Datum & Uhrzeit</label>
                            <input type="datetime-local" class="form-control" @bind="neuesDatum" />
                        </div>
                        <button class="btn btn-success w-100" @onclick="SpielHinzufuegen">Spiel hinzufügen</button>
                    </div>
                </div>
            </div>
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                        <span>Spiele verwalten</span>
                        <div>
                            <label class="me-2 text-dark">Filter:</label>
                            <select class="form-select form-select-sm d-inline-block" style="width: auto;" @bind="adminSpieltag">
                                <option value="">Alle Spieltage</option>
                                @foreach (var st in spieleListe.Select(s => s.Spieltag).Distinct().OrderBy(s => s))
                                {
                                    <option value="@st">@st</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="list-group list-group-flush" style="max-height: 500px; overflow-y: auto;">
                        @foreach (var gruppe in GetGefilterte().GroupBy(s => s.Spieltag).OrderBy(g => g.Key))
                        {
                            <div class="list-group-item bg-primary text-white fw-bold">SPIELTAG @gruppe.Key</div>
                            @foreach (var spiel in gruppe.OrderBy(s => s.SpielDatum))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@spiel.Heimmannschaft vs @spiel.Gastmannschaft</strong><br />
                                            <small class="text-muted">@spiel.SpielDatum.ToString("dd.MM.yyyy HH:mm")</small>
                                        </div>
                                        <div class="d-flex gap-1 align-items-center">
                                            <input type="number" class="form-control form-control-sm" style="width: 60px;" @bind="ergebnisseHeim[spiel.SpielNummer]" min="0" max="20" />
                                            <span>:</span>
                                            <input type="number" class="form-control form-control-sm" style="width: 60px;" @bind="ergebnisseGast[spiel.SpielNummer]" min="0" max="20" />
                                            <button class="btn btn-sm btn-warning" @onclick="@(() => ErgebnisEintragen(spiel))">
                                                @(spiel.IstBeendet() ? "Ändern" : "OK")
                                            </button>
                                            <button class="btn btn-sm btn-secondary" @onclick="@(() => SpielBearbeitenStart(spiel))">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="@(() => SpielLoeschen(spiel.SpielNummer))">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (tab == "bundesliga")
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-download"></i> Bundesliga Spielplan importieren</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Importiere Spiele direkt von OpenLigaDB (Bundesliga)
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Saison</label>
                        <select class="form-select" @bind="importSaison">
                            <option value="2025">2025/2026</option>
                            <option value="2024">2024/2025 (aktuell)</option>
                            <option value="2023">2023/2024</option>
                            <option value="2022">2022/2023</option>
                            <option value="2021">2021/2022</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Spieltag</label>
                        <input type="number" class="form-control" @bind="importSpieltag" min="1" max="34" placeholder="1-34" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">&nbsp;</label>
                        <button class="btn btn-primary w-100" @onclick="BundesligaSpieleImportieren" disabled="@importLaeuft">
                            @if (importLaeuft)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <text>Importiere...</text>
                            }
                            else
                            {
                                <i class="bi bi-download"></i>
                                <text> Spieltag importieren</text>
                            }
                        </button>
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-12">
                        <button class="btn btn-success w-100" @onclick="LiveErgebnisseAktualisieren" disabled="@liveUpdateLaeuft">
                            @if (liveUpdateLaeuft)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <text>Aktualisiere Live-Ergebnisse...</text>
                            }
                            else
                            {
                                <i class="bi bi-arrow-clockwise"></i>
                                <text> Live-Ergebnisse jetzt aktualisieren</text>
                            }
                        </button>
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-info-circle"></i> Aktualisiert alle offenen Spiele von heute automatisch
                        </small>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(importMeldung))
                {
                    <div class="alert @(importErfolgreich ? "alert-success" : "alert-danger")">
                        @importMeldung
                    </div>
                }
                
                @if (importierteSpiele.Any())
                {
                    <h6 class="mt-3">Gefundene Spiele (@importierteSpiele.Count):</h6>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Datum</th>
                                    <th>Heimmannschaft</th>
                                    <th>Gastmannschaft</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var spiel in importierteSpiele)
                                {
                                    <tr>
                                        <td>@spiel.MatchDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>@spiel.Team1.TeamName</td>
                                        <td>@spiel.Team2.TeamName</td>
                                        <td>
                                            @if (spiel.MatchIsFinished)
                                            {
                                                var (heim, gast) = spiel.GetErgebnis();
                                                <span class="badge bg-success">Beendet @heim:@gast</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Offen</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
    else if (tab == "tipps")
    {
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-clipboard-check"></i> Alle Tipps</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Nach Benutzer filtern:</label>
                        <select class="form-select" @bind="filterBenutzer">
                            <option value="">Alle Benutzer</option>
                            @foreach (var benutzer in benutzerListe.OrderBy(b => b.Benutzername))
                            {
                                <option value="@benutzer.Benutzername">@benutzer.Benutzername</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Nach Spieltag filtern:</label>
                        <select class="form-select" @bind="filterSpieltag">
                            <option value="">Alle Spieltage</option>
                            @foreach (var st in spieleListe.Select(s => s.Spieltag).Distinct().OrderBy(s => s))
                            {
                                <option value="@st">Spieltag @st</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Spielstatus:</label>
                        <select class="form-select" @bind="filterSpielstatus">
                            <option value="">Alle</option>
                            <option value="offen">Nur offene Spiele</option>
                            <option value="beendet">Nur beendete Spiele</option>
                        </select>
                    </div>
                </div>

                @{
                    var gefilterteSpiele = spieleListe.AsEnumerable();
                    
                    if (!string.IsNullOrEmpty(filterSpieltag))
                    {
                        gefilterteSpiele = gefilterteSpiele.Where(s => s.Spieltag == filterSpieltag);
                    }

                    if (filterSpielstatus == "offen")
                    {
                        gefilterteSpiele = gefilterteSpiele.Where(s => !s.IstBeendet());
                    }
                    else if (filterSpielstatus == "beendet")
                    {
                        gefilterteSpiele = gefilterteSpiele.Where(s => s.IstBeendet());
                    }

                    var spieleNachSpieltag = gefilterteSpiele.GroupBy(s => s.Spieltag).OrderBy(g => g.Key);
                }

                @if (!gefilterteSpiele.Any())
                {
                    <div class="alert alert-info">Keine Spiele gefunden.</div>
                }
                else
                {
                    @foreach (var gruppe in spieleNachSpieltag)
                    {
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white fw-bold">
                                SPIELTAG @gruppe.Key
                            </div>
                            <div class="card-body">
                                @foreach (var spiel in gruppe.OrderBy(s => s.SpielDatum))
                                {
                                    var spielTipps = spiel.Tipps;
                                    if (!string.IsNullOrEmpty(filterBenutzer))
                                    {
                                        spielTipps = spielTipps.Where(t => t.Key.Equals(filterBenutzer, StringComparison.OrdinalIgnoreCase))
                                            .ToDictionary(t => t.Key, t => t.Value);
                                    }

                                    <div class="border-bottom mb-3 pb-3">
                                        <div class="row mb-2">
                                            <div class="col-md-6">
                                                <strong>@spiel.Heimmannschaft vs @spiel.Gastmannschaft</strong><br />
                                                <small class="text-muted">@spiel.SpielDatum.ToString("dd.MM.yyyy HH:mm")</small>
                                            </div>
                                            <div class="col-md-6 text-end">
                                                @if (spiel.IstBeendet())
                                                {
                                                    <span class="badge bg-success">Beendet: @spiel.HeimTore:@spiel.GastTore</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Offen</span>
                                                }
                                                <br />
                                                <small class="text-muted">@spielTipps.Count Tipp(s) abgegeben</small>
                                            </div>
                                        </div>

                                        @if (spielTipps.Any())
                                        {
                                            <div class="table-responsive">
                                                <table class="table table-sm table-bordered mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Benutzer</th>
                                                            <th>Tipp</th>
                                                            @if (spiel.IstBeendet())
                                                            {
                                                                <th>Punkte</th>
                                                            }
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var tipp in spielTipps.OrderBy(t => t.Key))
                                                        {
                                                            <tr>
                                                                <td>@tipp.Key</td>
                                                                <td><strong>@tipp.Value.HeimTore:@tipp.Value.GastTore</strong></td>
                                                                @if (spiel.IstBeendet())
                                                                {
                                                                    var punkte = BerechneTippPunkte(tipp.Value, spiel);
                                                                    var bgClass = punkte == 3 ? "table-success" : punkte == 2 ? "table-warning" : punkte == 1 ? "table-info" : "";
                                                                    <td class="@bgClass">
                                                                        <strong>@punkte</strong>
                                                                        @if (punkte == 3) { <span>🎯 Exakt!</span> }
                                                                        else if (punkte == 2) { <span>👍 Differenz</span> }
                                                                        else if (punkte == 1) { <span>✓ Tendenz</span> }
                                                                    </td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning mb-0">
                                                Keine Tipps @(string.IsNullOrEmpty(filterBenutzer) ? "" : $"von {filterBenutzer}") abgegeben.
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    }
    else if (tab == "turniertipps")
    {
        <div class="card">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-trophy-fill"></i> Turniertipps aller Benutzer
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Benutzer</th>
                                <th><i class="bi bi-trophy text-warning"></i> Weltmeister</th>
                                <th><i class="bi bi-award text-secondary"></i> Vizemeister</th>
                                <th>Registriert am</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var benutzer in benutzerListe.OrderBy(b => b.Benutzername))
                            {
                                var hatTipp = !string.IsNullOrEmpty(benutzer.WeltmeisterTipp) || !string.IsNullOrEmpty(benutzer.VizemeisterTipp);
                                <tr class="@(hatTipp ? "" : "table-secondary")">
                                    <td>
                                        <strong>@benutzer.Benutzername</strong>
                                        @if (benutzer.IstAdmin)
                                        {
                                            <span class="badge bg-warning ms-1">Admin</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(benutzer.WeltmeisterTipp))
                                        {
                                            <span class="badge bg-success">@benutzer.WeltmeisterTipp</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(benutzer.VizemeisterTipp))
                                        {
                                            <span class="badge bg-info">@benutzer.VizemeisterTipp</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>@benutzer.RegistriertAm.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-3 alert alert-info">
                    <i class="bi bi-info-circle"></i> 
                    <strong>Statistik:</strong> 
                    @{
                        var mitTipp = benutzerListe.Count(b => !string.IsNullOrEmpty(b.WeltmeisterTipp) || !string.IsNullOrEmpty(b.VizemeisterTipp));
                        var ohneTipp = benutzerListe.Count - mitTipp;
                    }
                    @mitTipp von @benutzerListe.Count Benutzer haben einen Turniertipp abgegeben.
                    @if (ohneTipp > 0)
                    {
                        <span class="text-muted">(@ohneTipp noch ohne Tipp)</span>
                    }
                </div>
            </div>
        </div>
    }
    else if (tab == "tabelle")
    {
        <button class="btn btn-primary mb-3" @onclick="PunkteBerechnen">Punkte neu berechnen</button>
        
        <table class="table table-striped">
            <thead class="table-warning">
                <tr>
                    <th>Platz</th>
                    <th>Spieler</th>
                    <th>Punkte</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var sortiert = spielerListe.OrderByDescending(s => s.Punkte).ToList();
                    int platz = 1;
                    for (int i = 0; i < sortiert.Count; i++)
                    {
                        if (i > 0 && sortiert[i].Punkte < sortiert[i - 1].Punkte)
                            platz = i + 1;

                        var cssClass = platz == 1 ? "table-warning" : platz == 2 ? "table-secondary" : platz == 3 ? "table-danger" : "";

                        <tr class="@cssClass">
                            <td>@platz</td>
                            <td>@sortiert[i].Name</td>
                            <td>@sortiert[i].Punkte</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
    else if (tab == "export")
    {
        <div class="card">
            <div class="card-header bg-info text-white">Excel-Export</div>
            <div class="card-body">
                <p>Exportieren Sie alle Daten als Excel-Datei.</p>
                <button class="btn btn-success" @onclick="ExcelExportieren">Excel herunterladen</button>
            </div>
        </div>
    }
</div>

<datalist id="mannschaften-liste">
    @foreach (var mannschaft in mannschaftsListe)
    {
        <option value="@mannschaft.Name">@mannschaft.Name</option>
    }
</datalist>

<div class="mt-3">
    <button class="btn btn-secondary" @onclick="@(() => Navigation.NavigateTo("/login"))">Zurück zum Login</button>
</div>

@code {
    private string tab = "mannschaften";
    private List<Benutzer> benutzerListe = new();
    private List<Spieler> spielerListe = new();
    private List<Spiel> spieleListe = new();
    private List<Mannschaft> mannschaftsListe = new();
    private string adminSpieltag = "";
    
    // Mannschaften-Verwaltung
    private string neueMannschaft = "";
    private string mannschaftsMeldung = "";
    private string? bearbeiteteMannschaft = null;
    private string neuerMannschaftsname = "";
    
    // Tipps-Filter
    private string filterBenutzer = "";
    private string filterSpieltag = "";
    private string filterSpielstatus = "";
    
    // Benutzerverwaltung
    private string benutzerMeldung = "";
    private string? bearbeiteterBenutzer = null;
    private string neuerBenutzernameAdmin = "";
    private bool zeigePasswortReset = false;
    private string resetBenutzer = "";
    private string neuesPasswortAdmin = "";
    private string neuesPasswortAdminWiederholung = "";
    
    private string neuerSpieltag = "1";
    private string neueHeimmannschaft = "";
    private string neueGastmannschaft = "";
    private DateTime neuesDatum = DateTime.Now;
    
    private Dictionary<int, int> ergebnisseHeim = new();
    private Dictionary<int, int> ergebnisseGast = new();
    
    private Spiel? bearbeitungsSpiel = null;
    private string bearbeitungSpieltag = "1";
    private string bearbeitungHeimmannschaft = "";
    private string bearbeitungGastmannschaft = "";
    private DateTime bearbeitungDatum = DateTime.Now;

    protected override void OnInitialized()
    {
        // Initiales vollständiges Laden aller Daten
        Aktualisieren(vollstaendig: true);
    }

    private List<Spiel> GetGefilterte()
    {
        if (string.IsNullOrEmpty(adminSpieltag))
            return spieleListe;
        return spieleListe.Where(s => s.Spieltag == adminSpieltag).ToList();
    }

    private void Aktualisieren(bool vollstaendig = true)
    {
        Console.WriteLine($"Aktualisieren aufgerufen: vollstaendig={vollstaendig}, aktueller Tab={tab}");
        
        // Bei vollständigem Update: Lade alle Basisdaten
        if (vollstaendig)
        {
            benutzerListe = TippspielService.GetAlleBenutzer();
            spielerListe = TippspielService.GetAlleSpieler();
            mannschaftsListe = TippspielService.GetAlleMannschaften();
            spieleListe = TippspielService.GetAlleSpiele();
            
            Console.WriteLine($"Vollständiges Laden: {benutzerListe?.Count ?? 0} Benutzer, {spielerListe?.Count ?? 0} Spieler, {mannschaftsListe?.Count ?? 0} Mannschaften, {spieleListe?.Count ?? 0} Spiele");
            
            // Initialisiere Eingabefelder für alle Spiele
            foreach (var spiel in spieleListe)
            {
                if (spiel.IstBeendet())
                {
                    ergebnisseHeim[spiel.SpielNummer] = spiel.HeimTore ?? 0;
                    ergebnisseGast[spiel.SpielNummer] = spiel.GastTore ?? 0;
                }
                else
                {
                    ergebnisseHeim.TryAdd(spiel.SpielNummer, 0);
                    ergebnisseGast.TryAdd(spiel.SpielNummer, 0);
                }
            }
            return;
        }
        
        // Bei selektivem Update: Lade nur die Daten für den aktuellen Tab
        if (tab == "benutzer")
        {
            benutzerListe = TippspielService.GetAlleBenutzer();
            Console.WriteLine($"Benutzer-Tab: {benutzerListe?.Count ?? 0} Benutzer geladen");
        }
            
        if (tab == "tabelle" || tab == "export")
            spielerListe = TippspielService.GetAlleSpieler();
            
        if (tab == "spiele" || tab == "bundesliga" || tab == "tipps" || tab == "export")
        {
            spieleListe = TippspielService.GetAlleSpiele();
            
            // Initialisiere Eingabefelder für alle Spiele
            foreach (var spiel in spieleListe)
            {
                if (spiel.IstBeendet())
                {
                    ergebnisseHeim[spiel.SpielNummer] = spiel.HeimTore ?? 0;
                    ergebnisseGast[spiel.SpielNummer] = spiel.GastTore ?? 0;
                }
                else
                {
                    ergebnisseHeim.TryAdd(spiel.SpielNummer, 0);
                    ergebnisseGast.TryAdd(spiel.SpielNummer, 0);
                }
            }
        }
        
        if (tab == "mannschaften" || tab == "spiele")
            mannschaftsListe = TippspielService.GetAlleMannschaften();
    }
    
    private void WechsleTab(string neuerTab)
    {
        tab = neuerTab;
        // Lade Daten für den neuen Tab
        Aktualisieren(vollstaendig: false);
        
        // Debug-Output
        Console.WriteLine($"Tab gewechselt zu: {tab}");
        if (tab == "benutzer")
        {
            Console.WriteLine($"Benutzer geladen: {benutzerListe?.Count ?? 0}");
        }
    }

    private void SpielHinzufuegen()
    {
        if (!string.IsNullOrEmpty(neueHeimmannschaft) && !string.IsNullOrEmpty(neueGastmannschaft))
        {
            TippspielService.SpielHinzufuegen(neuerSpieltag, neueHeimmannschaft, neueGastmannschaft, neuesDatum);
            neueHeimmannschaft = "";
            neueGastmannschaft = "";
            neuesDatum = DateTime.Now;
            Aktualisieren();
        }
    }

    private void ErgebnisEintragen(Spiel spiel)
    {
        if (ergebnisseHeim.ContainsKey(spiel.SpielNummer) && ergebnisseGast.ContainsKey(spiel.SpielNummer))
        {
            TippspielService.ErgebnisEintragen(spiel.SpielNummer, ergebnisseHeim[spiel.SpielNummer], ergebnisseGast[spiel.SpielNummer]);
            Aktualisieren();
        }
    }

    private void PunkteBerechnen()
    {
        TippspielService.PunkteBerechnen();
        Aktualisieren();
    }

    private void SpielBearbeitenStart(Spiel spiel)
    {
        bearbeitungsSpiel = spiel;
        bearbeitungSpieltag = spiel.Spieltag;
        bearbeitungHeimmannschaft = spiel.Heimmannschaft;
        bearbeitungGastmannschaft = spiel.Gastmannschaft;
        bearbeitungDatum = spiel.SpielDatum;
    }

    private void SpielBearbeitenSpeichern()
    {
        if (bearbeitungsSpiel != null && 
            !string.IsNullOrEmpty(bearbeitungHeimmannschaft) && 
            !string.IsNullOrEmpty(bearbeitungGastmannschaft))
        {
            TippspielService.SpielBearbeiten(
                bearbeitungsSpiel.SpielNummer, 
                bearbeitungSpieltag, 
                bearbeitungHeimmannschaft, 
                bearbeitungGastmannschaft, 
                bearbeitungDatum
            );
            bearbeitungsSpiel = null;
            Aktualisieren();
        }
    }

    private void SpielBearbeitenAbbrechen()
    {
        bearbeitungsSpiel = null;
    }

    private void SpielLoeschen(int spielNummer)
    {
        if (TippspielService.SpielLoeschen(spielNummer))
        {
            Aktualisieren();
        }
    }

    // Benutzerverwaltung-Methoden
    private void BenutzernameAendernAdmin(string alterBenutzername)
    {
        benutzerMeldung = "";
        
        if (string.IsNullOrWhiteSpace(neuerBenutzernameAdmin))
        {
            benutzerMeldung = "Benutzername darf nicht leer sein.";
            return;
        }

        if (TippspielService.BenutzernameAendern(alterBenutzername, neuerBenutzernameAdmin))
        {
            benutzerMeldung = $"Benutzername '{alterBenutzername}' wurde erfolgreich in '{neuerBenutzernameAdmin}' geändert.";
            bearbeiteterBenutzer = null;
            Aktualisieren();
        }
        else
        {
            benutzerMeldung = "Fehler beim Ändern des Benutzernamens. Name ist möglicherweise bereits vergeben.";
        }
    }

    private void PasswortZuruecksetzen(string benutzername)
    {
        resetBenutzer = benutzername;
        zeigePasswortReset = true;
        neuesPasswortAdmin = "";
        neuesPasswortAdminWiederholung = "";
    }

    private void PasswortZuruecksetzenBestaetigen()
    {
        benutzerMeldung = "";

        if (string.IsNullOrEmpty(neuesPasswortAdmin) || neuesPasswortAdmin.Length < 6)
        {
            benutzerMeldung = "Passwort muss mindestens 6 Zeichen lang sein.";
            return;
        }

        if (neuesPasswortAdmin != neuesPasswortAdminWiederholung)
        {
            benutzerMeldung = "Passwörter stimmen nicht überein.";
            return;
        }

        if (TippspielService.PasswortAendernAlsAdmin(resetBenutzer, neuesPasswortAdmin))
        {
            benutzerMeldung = $"Passwort für '{resetBenutzer}' wurde erfolgreich zurückgesetzt.";
            zeigePasswortReset = false;
            neuesPasswortAdmin = "";
            neuesPasswortAdminWiederholung = "";
            resetBenutzer = "";
        }
        else
        {
            benutzerMeldung = "Fehler beim Zurücksetzen des Passworts.";
        }
    }

    private void BenutzerLoeschenAdmin(string benutzername)
    {
        benutzerMeldung = "";

        if (TippspielService.BenutzerLoeschen(benutzername))
        {
            benutzerMeldung = $"Benutzer '{benutzername}' wurde erfolgreich gelöscht.";
            Aktualisieren();
        }
        else
        {
            benutzerMeldung = "Fehler beim Löschen des Benutzers.";
        }
    }

    private int BerechneTippPunkte(Tipp tipp, Spiel spiel)
    {
        if (!spiel.IstBeendet()) return 0;

        int heimTore = spiel.HeimTore ?? 0;
        int gastTore = spiel.GastTore ?? 0;

        if (tipp.HeimTore == heimTore && tipp.GastTore == gastTore)
            return 3;

        int tippDiff = tipp.HeimTore - tipp.GastTore;
        int spielDiff = heimTore - gastTore;

        if (tippDiff == spielDiff)
            return 2;

        if ((tippDiff > 0 && spielDiff > 0) || 
            (tippDiff == 0 && spielDiff == 0) || 
            (tippDiff < 0 && spielDiff < 0))
            return 1;

        return 0;
    }
    
    // Mannschaften-Methoden
    private void MannschaftHinzufuegen()
    {
        if (!string.IsNullOrEmpty(neueMannschaft))
        {
            bool erfolg = TippspielService.MannschaftHinzufuegen(neueMannschaft);
            if (erfolg)
            {
                mannschaftsMeldung = $"Mannschaft '{neueMannschaft}' wurde hinzugefügt.";
                neueMannschaft = "";
                Aktualisieren();
            }
            else
            {
                mannschaftsMeldung = $"Mannschaft '{neueMannschaft}' existiert bereits.";
            }
        }
    }
    
    private void MannschaftLoeschen(string name)
    {
        TippspielService.MannschaftLoeschen(name);
        mannschaftsMeldung = $"Mannschaft '{name}' wurde gelöscht.";
        Aktualisieren();
    }
    
    private void MannschaftUmbenennenSpeichern(string alterName)
    {
        if (!string.IsNullOrEmpty(neuerMannschaftsname))
        {
            bool erfolg = TippspielService.MannschaftUmbenennen(alterName, neuerMannschaftsname);
            if (erfolg)
            {
                mannschaftsMeldung = $"Mannschaft '{alterName}' wurde zu '{neuerMannschaftsname}' umbenannt.";
                bearbeiteteMannschaft = null;
                neuerMannschaftsname = "";
                Aktualisieren();
            }
            else
            {
                mannschaftsMeldung = $"Mannschaft '{neuerMannschaftsname}' existiert bereits.";
            }
        }
    }

    private async Task ExcelExportieren()
    {
        var excelDaten = TippspielService.ExportiereNachExcel();
        await JS.InvokeVoidAsync("downloadFile", "Tippspiel.xlsx", Convert.ToBase64String(excelDaten));
    }

    // Bundesliga Import
    private int importSaison = 2024;
    private int importSpieltag = 1;
    private bool importLaeuft = false;
    private string importMeldung = "";
    private bool importErfolgreich = false;
    private List<OpenLigaMatch> importierteSpiele = new();

    private async Task BundesligaSpieleImportieren()
    {
        importLaeuft = true;
        importMeldung = "";
        importErfolgreich = false;
        importierteSpiele.Clear();
        StateHasChanged();

        try
        {
            var spiele = await OpenLigaDBService.GetAktuellerSpieltagAsync(importSaison, importSpieltag);
            
            if (spiele == null || !spiele.Any())
            {
                importMeldung = "Keine Spiele gefunden für diese Saison/Spieltag-Kombination.";
                importErfolgreich = false;
                return;
            }

            importierteSpiele = spiele;
            int importiert = 0;

            Console.WriteLine($"Starte Import von {spiele.Count} Spielen...");

            foreach (var match in spiele)
            {
                Console.WriteLine($"Importiere: {match.Team1.TeamName} vs {match.Team2.TeamName} am {match.MatchDateTime}");
                
                // Mannschaften automatisch hinzufügen falls nicht vorhanden
                TippspielService.MannschaftHinzufuegen(match.Team1.TeamName);
                TippspielService.MannschaftHinzufuegen(match.Team2.TeamName);

                // Spiel hinzufügen
                TippspielService.SpielHinzufuegen(
                    match.Group.GroupName,
                    match.Team1.TeamName,
                    match.Team2.TeamName,
                    match.MatchDateTime
                );

                importiert++;
                Console.WriteLine($"Spiel {importiert}/{spiele.Count} importiert");
                
                // Falls Spiel beendet ist, Ergebnis eintragen
                if (match.MatchIsFinished)
                {
                    var (heim, gast) = match.GetErgebnis();
                    if (heim.HasValue && gast.HasValue)
                    {
                        var spielNummer = TippspielService.GetAlleSpiele()
                            .Where(s => s.Heimmannschaft == match.Team1.TeamName && 
                                       s.Gastmannschaft == match.Team2.TeamName &&
                                       s.SpielDatum.Date == match.MatchDateTime.Date)
                            .FirstOrDefault()?.SpielNummer;
                        
                        if (spielNummer.HasValue)
                        {
                            TippspielService.ErgebnisEintragen(spielNummer.Value, heim.Value, gast.Value);
                        }
                    }
                }
            }

            importMeldung = $"Erfolgreich {importiert} von {spiele.Count} Spielen importiert!";
            importErfolgreich = true;
        }
        catch (Exception ex)
        {
            importMeldung = $"Fehler beim Import: {ex.Message}";
            importErfolgreich = false;
        }
        finally
        {
            importLaeuft = false;
            Aktualisieren();
            StateHasChanged();
        }
    }

    // Live-Ergebnisse aktualisieren
    private bool liveUpdateLaeuft = false;

    private async Task LiveErgebnisseAktualisieren()
    {
        liveUpdateLaeuft = true;
        importMeldung = ""; // Clear import message
        StateHasChanged();

        try
        {
            var alleSpiele = TippspielService.GetAlleSpiele();
            var heuteSpiele = alleSpiele.Where(s => 
                s.SpielDatum.Date == DateTime.Today && 
                !s.IstBeendet()
            ).ToList();

            if (!heuteSpiele.Any())
            {
                importMeldung = "Keine offenen Spiele heute gefunden.";
                importErfolgreich = false;
                return;
            }

            var liveSpiele = await OpenLigaDBService.GetLiveSpieleAsync();
            if (liveSpiele == null || !liveSpiele.Any())
            {
                importMeldung = "Konnte keine Live-Daten von OpenLigaDB abrufen.";
                importErfolgreich = false;
                return;
            }

            int aktualisiert = 0;
            foreach (var spiel in heuteSpiele)
            {
                var liveSpiel = liveSpiele.FirstOrDefault(ls => 
                    ls.Team1.TeamName == spiel.Heimmannschaft &&
                    ls.Team2.TeamName == spiel.Gastmannschaft &&
                    ls.MatchDateTime.Date == spiel.SpielDatum.Date
                );

                if (liveSpiel != null && liveSpiel.MatchIsFinished)
                {
                    var (heim, gast) = liveSpiel.GetErgebnis();
                    if (heim.HasValue && gast.HasValue)
                    {
                        TippspielService.ErgebnisEintragen(spiel.SpielNummer, heim.Value, gast.Value);
                        aktualisiert++;
                    }
                }
            }

            if (aktualisiert > 0)
            {
                importMeldung = $"✅ {aktualisiert} Spiel-Ergebnisse wurden aktualisiert!";
                importErfolgreich = true;
                Aktualisieren();
            }
            else
            {
                importMeldung = $"Keine neuen Ergebnisse gefunden. {heuteSpiele.Count} Spiel(e) von heute noch offen.";
                importErfolgreich = true;
            }
        }
        catch (Exception ex)
        {
            importMeldung = $"Fehler beim Live-Update: {ex.Message}";
            importErfolgreich = false;
        }
        finally
        {
            liveUpdateLaeuft = false;
            StateHasChanged();
        }
    }
}
